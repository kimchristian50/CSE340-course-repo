<%- include('partials/header') %>

    <main>
        <h1>
            <%= title %>
        </h1>
        <h2>
            <%= project.title %>
        </h2>
        <p>
            <%= project.description %>
        </p>
        <p>
            <%= project.date.toLocaleDateString('en-US', { month: 'long' , day: 'numeric' , year: 'numeric' }) %> - <%=
                    project.location %>
        </p>
        <h3>Categories:</h3>
        <ul>
            <% categories.forEach(category=> { %>
                <li>
                    <a href="/category/<%= category.category_id %>" class="tag">
                        <%= category.name %>
                    </a>

                </li>
                <% }); %>

        </ul>
        <a href="/assign-categories/<%= project.project_id %>">Edit Categories</a>
        <p>Sponsored by:
            <a href="/organization/<%= project.organization_id %>">
                <%= project.organization_name %>
            </a>
        </p>

    </main>
    <%- include('partials/footer') %>